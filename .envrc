use flake .

# Load sops-encrypted AI/Comfy settings. secrets/local.env is committed to git
# but encrypted via sops to the recipients in .sops.yaml.
if [ -f secrets/local.env ] && command -v sops >/dev/null; then
  eval "$(sops -d --output-type dotenv secrets/local.env 2>/dev/null | sed 's/^/export /')"
fi
source_env_if_exists .envrc.local
