{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/brand/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "ui_kits/landing/**",
              "ui_kits/studio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Noto Serif SC|Noto Sans SC|Ma Shan Zheng|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Noto Serif SC, Noto Sans SC, Ma Shan Zheng, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|square|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring, square."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, solid."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|gold|jade|moon|danger)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'gold' | 'jade' | 'moon' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|loading|disabled|full|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, loading, disabled, full."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:gold|jade|outline|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'gold' | 'jade' | 'outline' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|cut|glow|interactive|padding|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, cut, glow, interactive, padding."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='glow'] > Literal[value!=/^(?:none|gold|jade)$/]",
        "message": "<Card> glow must be one of 'none' | 'gold' | 'jade'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CornerFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|cornerSize|bordered|pad|key|ref|className|style|children)$/]",
        "message": "<CornerFrame> doesn't accept that prop. Declared props: children, cornerSize, bordered, pad."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|children|footer|width|cut|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, onClose, title, children, footer, width, cut, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|variant|active|label|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, size, variant, active, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:ghost|surface|gold)$/]",
        "message": "<IconButton> variant must be one of 'ghost' | 'surface' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|suffix|size|invalid|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon, suffix, size, invalid, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|active|count|onClick|key|ref|className|style|children)$/]",
        "message": "<NavItem> doesn't accept that prop. Declared props: children, icon, active, count, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrbIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|active|framed|glow|onClick|key|ref|className|style|children)$/]",
        "message": "<OrbIcon> doesn't accept that prop. Declared props: name, size, active, framed, glow, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrbIcon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:emblem|crystal|scroll|censer|gourd|pagoda|sword|portal|scroll-bamboo|book|meditation|mountain|taiji|crane|starchart|pouch|talisman|gem|beast|shrine|brush|chest)$/]",
        "message": "<OrbIcon> name must be one of 'emblem' | 'crystal' | 'scroll' | 'censer' | 'gourd' | 'pagoda' | 'sword' | 'portal' | 'scroll-bamboo' | 'book' | 'meditation' | 'mountain' | 'taiji' | 'crane' | 'starchart' | 'pouch' | 'talisman' | 'gem' | 'beast' | 'shrine' | 'brush' | 'chest'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrnateButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|full|disabled|key|ref|className|style|children)$/]",
        "message": "<OrnateButton> doesn't accept that prop. Declared props: children, variant, size, icon, full, disabled."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrnateButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:teal|paper)$/]",
        "message": "<OrnateButton> variant must be one of 'teal' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrnateButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<OrnateButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OrnatePanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|surface|padding|slice|glow|key|ref|className|style|children)$/]",
        "message": "<OrnatePanel> doesn't accept that prop. Declared props: children, surface, padding, slice, glow."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|tone|height|label|animated|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, tone, height, label, animated."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|jade|moon)$/]",
        "message": "<ProgressBar> tone must be one of 'gold' | 'jade' | 'moon'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PromptInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|placeholder|onGenerate|cost|footer|style|key|ref|className|style|children)$/]",
        "message": "<PromptInput> doesn't accept that prop. Declared props: value, onChange, placeholder, onGenerate, cost, footer, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|size|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, onChange, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<SegmentedControl> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: size, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Select> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpiritStone'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|size|onAdd|low|art|key|ref|className|style|children)$/]",
        "message": "<SpiritStone> doesn't accept that prop. Declared props: count, size, onAdd, low, art."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpiritStone'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<SpiritStone> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpiritStone'] > JSXAttribute[name.name='art'] > Literal[value!=/^(?:crystal|diamond)$/]",
        "message": "<SpiritStone> art must be one of 'crystal' | 'diamond'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|icon|disabled|onClick|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, selected, icon, disabled, onClick."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
